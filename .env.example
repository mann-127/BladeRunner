# BladeRunner Environment Variables
# Copy this file to .env and fill in your API keys

# OpenRouter API Key (default backend)
# Get your key from: https://openrouter.ai/keys
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# Groq API Key (automatic fallback backend)
# Get your key from: https://console.groq.com/keys
# TIP: Set this to enable automatic fallback when OpenRouter hits rate/credit limits
# GROQ_API_KEY=your_groq_api_key_here

# Google AI API Key (for Google ADK/Gemini engine)
# Get your key from: https://aistudio.google.com/apikey
# GOOGLE_API_KEY=your_google_api_key_here

# Brave Search API Key (optional - DuckDuckGo is used by default)
# Get your key from: https://brave.com/search/api
# Provides higher quality search results (2,000 free queries/month)
# BRAVE_API_KEY=your_brave_api_key_here

# API auth keys for FastAPI service (optional, comma-separated)
# Used when api.auth.enabled=true in config.yml
# BLADERUNNER_API_KEYS=prod_key_1,prod_key_2

# JWT secret key for token-based authentication (production)
# Generate a secure random string: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Used when api.auth.jwt.enabled=true in config.yml
# BLADERUNNER_JWT_SECRET=your_secure_random_secret_here

# AUTOMATIC FALLBACK:
# If you set up multiple backend keys, BladeRunner will automatically
# switch backends when it encounters:
# - Rate limits (429 errors)
# - Credit/payment limits (402 errors)
# - Repeated failures
# This ensures uninterrupted service across free and paid tiers!
